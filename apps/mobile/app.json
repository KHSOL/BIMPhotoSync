{
  "expo": {
    "name": "BIM Photo Sync",
    "slug": "bim-photo-sync",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "bimphotosync",
    "userInterfaceStyle": "light",
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "현장 사진 업로드를 위해 사진 보관함 접근이 필요합니다.",
          "cameraPermission": "현장 사진 촬영을 위해 카메라 접근이 필요합니다.",
          "microphonePermission": false
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bimphotosync.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bimphotosync.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#2563EB"
      }
    },
    "extra": {
      "apiBaseUrl": "https://api-production-1d018.up.railway.app/api/v1",
      "eas": {
        "projectId": "c67aaba8-2622-4ea4-b17d-bb34a380d088"
      }
    },
    "owner": "khsol"
  }
}
