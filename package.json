{
  "name": "bim-photo-sync",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev-full.mjs",
    "dev:api": "npm --workspace apps/api run start:dev",
    "dev:worker": "npm --workspace apps/ai-worker run start:dev",
    "dev:web": "npm --workspace apps/web run dev",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "build": "npm --workspaces --if-present run build",
    "create:super-admin": "node scripts/create-super-admin.mjs"
  },
  "overrides": {
    "@nestjs/common": "11.1.24",
    "@nestjs/core": "11.1.24",
    "@nestjs/platform-express": "11.1.24",
    "@nestjs/testing": "11.1.24",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@nestjs/common": "11.1.24",
    "@nestjs/core": "11.1.24",
    "@nestjs/platform-express": "11.1.24",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "webidl-conversions": "^5.0.0"
  },
  "engines": {
    "node": ">=20 <24"
  }
}
