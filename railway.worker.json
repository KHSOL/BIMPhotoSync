{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.worker",
    "watchPatterns": [
      "Dockerfile.worker",
      "package.json",
      "package-lock.json",
      "apps/ai-worker/**",
      "apps/api/prisma/**",
      "packages/shared/**"
    ]
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
